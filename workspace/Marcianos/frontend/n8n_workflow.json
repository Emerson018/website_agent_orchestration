    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const configData = $('Buscar Configs').all();\n  const bookings = $input.all();\n  \n  const configs = {};\n  for (const c of configData) {\n    configs[c.json.chave] = c.json.valor;\n  }\n  \n  const diasFuncionamento = configs.dias_funcionamento || [2, 3, 4, 5, 6, 0];\n  const horariosDisponiveis = configs.horarios_disponiveis || [\"18:30\", \"19:00\", \"19:30\", \"20:00\", \"20:30\", \"21:00\", \"21:30\", \"22:00\"];\n  const vagasPadrao = configs.vagas_padrao !== undefined ? configs.vagas_padrao : 5;\n  const limitesCustomizados = configs.limites_customizados || {};\n  \n  const weekdaysPT = [\"Dom\", \"Seg\", \"Ter\", \"Qua\", \"Qui\", \"Sex\", \"Sáb\"];\n  let resultText = \"📅 *VAGAS E HORÁRIOS DISPONÍVEIS*\\n*(Próximos 7 dias de funcionamento)*\\n\\n\";\n  \n  const current = new Date();\n  let daysCount = 0;\n  \n  for (let i = 0; i < 15; i++) {\n    const dateObj = new Date(current.getTime() + i * 24 * 60 * 60 * 1000);\n    const weekday = dateObj.getDay();\n    \n    if (!diasFuncionamento.includes(weekday)) continue;\n    \n    const weekdayLabel = weekdaysPT[weekday];\n    const dateStrStr = dateObj.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });\n    const year = dateObj.getFullYear();\n    const month = String(dateObj.getMonth() + 1).padStart(2, '0');\n    const day = String(dateObj.getDate()).padStart(2, '0');\n    const dateKey = `${year}-${month}-${day}`;\n    \n    let dayAvailableSlots = [];\n    \n    for (const time of [...horariosDisponiveis].sort()) {\n      const limit = limitesCustomizados[dateKey]?.[time] !== undefined \n        ? limitesCustomizados[dateKey][time] \n        : vagasPadrao;\n      \n      const occupied = bookings.filter(b => {\n        if (!b.json.inicio) return false;\n        const parts = b.json.inicio.split('T');\n        const bDate = parts[0];\n        const bTime = parts[1]?.slice(0, 5);\n        return bDate === dateKey && bTime === time;\n      }).length;\n      \n      const remaining = Math.max(0, limit - occupied);\n      if (remaining > 0) {\n        dayAvailableSlots.push(`${time} (${remaining}v)`);\n      }\n    }\n    \n    if (dayAvailableSlots.length > 0) {\n      resultText += `*${weekdayLabel} (${dateStrStr}):*\\n👉 ${dayAvailableSlots.join(' | ')}\\n\\n`;\n    } else {\n      resultText += `*${weekdayLabel} (${dateStrStr}):*\\n❌ Esgotado\\n\\n`;\n    }\n    \n    daysCount++;\n    if (daysCount >= 7) break;\n  }\n  \n  resultText += \"Para reservar a sua mesa, basta digitar *1* ou acessar o link abaixo:\\n🔗 http://localhost:5173/agendar\";\n  \n  item.json.resultText = resultText;\n}\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
