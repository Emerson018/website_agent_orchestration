    {
      "parameters": {
        "jsCode": "const dados = $('Dados').item.json;\nconst clean = (dados.senderPhone || dados.chatId).replace('@c.us', '').replace('@s.whatsapp.net', '').replace('@lid', '');\nlet number = clean.startsWith('55') ? clean.slice(2) : clean;\nconst ddd = number.slice(0, 2);\nconst rest = number.slice(2);\n\nlet formatWith9 = '';\nlet formatWithout9 = '';\n\nif (rest.length === 9) {\n  formatWith9 = `(${ddd}) ${rest.slice(0, 5)}-${rest.slice(5)}`;\n  formatWithout9 = `(${ddd}) ${rest.slice(1, 5)}-${rest.slice(5)}`;\n} else {\n  formatWithout9 = `(${ddd}) ${rest.slice(0, 4)}-${rest.slice(4)}`;\n  formatWith9 = `(${ddd}) 9${rest.slice(0, 4)}-${rest.slice(4)}`;\n}\n\nreturn [\n  {\n    json: {\n      formatWith9,\n      formatWithout9\n    }\n  }\n];"
      },
