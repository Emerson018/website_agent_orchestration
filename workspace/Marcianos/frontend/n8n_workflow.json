    {
      "parameters": {
        "jsCode": "const clients = $input.all();\nlet bookingFound = null;\nlet clientName = null;\n\nfor (const item of clients) {\n  const client = item.json;\n  if (client && client.agendamentos_base && client.agendamentos_base.length > 0) {\n    const activeBookings = client.agendamentos_base.filter(b => b.status !== 'Cancelado');\n    if (activeBookings.length > 0) {\n      activeBookings.sort((a, b) => new Date(a.inicio) - new Date(b.inicio));\n      const nearest = activeBookings[0];\n      if (!bookingFound || new Date(nearest.inicio) < new Date(bookingFound.inicio)) {\n        bookingFound = nearest;\n        clientName = client.nome;\n      }\n    }\n  }\n}\n\nif (!clientName && clients.length > 0) {\n  clientName = clients[0].json.nome || null;\n}\n\nreturn [\n  {\n    json: {\n      bookingFound,\n      clientName\n    }\n  }\n];"
      },
